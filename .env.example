# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will never be committed

# Cloudflare R2 — used by scripts/lib/r2-client.js (render -> upload pipeline,
# scripts/migrate-media-to-r2.js). Get the endpoint + keys from the Cloudflare
# dashboard: R2 -> Manage API Tokens (Object Read & Write, scoped to the bucket).
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# KIE.AI — Generative content engine (images, video, voice, music)
KIE_API_KEY=your_kie_api_key_here
KIE_BASE_URL=https://api.kie.ai/api/v1
KIE_DRY_RUN=true                          # set to false to enable real generation
KIE_ELEVENLABS_VOICE_ID=hpp4J3VqNfWAUOO0d1Us  # NoiraCiel artist voice

# Anthropic — Claude API for the NoiraCiel chatbot AND the NoiraCiel Speaker
# Get key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NoiraCiel Speaker (the /speaker page) — optional model override.
# Defaults to claude-haiku-4-5-20251001 if unset.
NOIRACIEL_SPEAKER_MODEL=claude-haiku-4-5-20251001

# ─── The Invisible Roots Scholarship ──────────────────────────────────────────
# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin token — any strong random string you choose
# Protects the /scholarship/admin page and all /api/scholarship/admin routes
SCHOLARSHIP_ADMIN_TOKEN=change-this-to-a-strong-random-string

# Separate admin token for /admin/pipeline (asset-coverage dashboard) — kept
# distinct from SCHOLARSHIP_ADMIN_TOKEN so a leak of one doesn't expose the other
PIPELINE_ADMIN_TOKEN=change-this-to-a-strong-random-string

# Public URL (used in Stripe redirect URLs when running in production)
NEXT_PUBLIC_URL=https://noiraciel.com
